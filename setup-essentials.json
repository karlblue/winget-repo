    {
      "id": "Apache.OpenOffice",
      "name": "OpenOffice",
      "description": "OpenOffice 是一个离线文档编辑软件。",
      "version": "4.116.9816",
      "icon_url": "https://dl.volan.top/winget-repo/images/apache-openoffice.png",
      "post_install": [
        {
          "type": "command",
          "run": "\"C:\\Program Files (x86)\\OpenOffice 4\\program\\soffice.exe\" -headless -nologo -nodefault",
          "delay_ms": 2000
        },
        {
          "type": "file_copy",
          "src": "https://karlblue.github.io/winget-repo/post-install-config/openoffice/registrymodifications.xcu",
          "dest": "%APPDATA%\\OpenOffice\\4\\user\\registrymodifications.xcu"
        },
        {
          "type": "file_copy",
          "src": "https://karlblue.github.io/winget-repo/post-install-config/openoffice/historymanager2.1.oxt",
          "dest": "%TEMP%\\win-softmgr\\historymanager2.1.oxt"
        },
        {
          "type": "command",
          "run": "echo y | \"C:\\Program Files (x86)\\OpenOffice 4\\program\\unopkg.com\" add --shared -s \"%TEMP%\\win-softmgr\\historymanager2.1.oxt\"",
          "delay_ms": 2000
        }
      ]
    },
