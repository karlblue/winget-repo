{
  "version": "0.1",
  "essentials": [
    {
      "id": "7zip.7zip",
      "name": "7Zip",
      "description": "7zip 是一个压缩软件。",
      "version": null,
      "icon_url": "https://dl.volan.top/winget-repo/images/7-zip.svg",
      "post_install": [
        {
          "type": "file_delete",
          "path": "C:\\Program Files\\7-Zip\\7-zip.chm"
        }
      ]
    },
    {
      "id": "Adobe.Acrobat.Reader.64-bit",
      "name": "Adobe Acrobat Reader",
      "description": "Adobe Acrobat Reader 是一个免费的 PDF 查看器。",
      "version": null,
      "icon_url": "https://dl.volan.top/winget-repo/images/adobe-acrobat-reader.png",
      "post_install": [
        {
          "type": "registry_batch",
          "root": "HKCU",
          "base_path": "Software\\Adobe\\Adobe Acrobat\\DC\\AVGeneral",
          "values": {
            "iMaxMRUCntToBeStored": {
              "v_type": "Dword",
              "data": 0
            }
          }
        }
      ]
    },
    {
