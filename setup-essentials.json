      "version": null,
      "icon_url": "https://dl.volan.top/winget-repo/images/file-shredder.png",
      "post_install": [
        {
          "type": "registry_batch",
          "root": "HKCU",
          "base_path": "Software\\Shredder\\Settings",
          "values": {
            "DefaultAlgorithm_ItemIndex": {
              "v_type": "Dword",
              "data": 3
            }
          }
        },
        {
          "type": "file_copy",
          "src": "https://karlblue.github.io/winget-repo/post-install-config/fileshredder/File-Shredder.lnk",
          "dest": "%USERPROFILE%\\Desktop\\File Shredder.lnk"
